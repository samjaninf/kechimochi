{
  "name": "kechimochi",
  "private": true,
  "version": "0.2.12",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": "^22.13.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "web": "npm run web:build && npm run web:server",
    "web:build": "tsc && vite build",
    "web:release": "npm run web:build && cargo build --locked --manifest-path src-tauri/Cargo.toml --bin web_server --release",
    "web:server": "cross-env PORT=3000 cargo run --locked --manifest-path src-tauri/Cargo.toml --bin web_server",
    "tauri": "tauri",
    "e2e:build": "tauri build --debug --no-bundle",
    "e2e:seed": "tsx e2e/fixtures/seed.ts",
    "e2e:test": "npm run e2e:seed && npm run e2e:build && wdio run e2e/wdio/wdio.conf.ts",
    "e2e": "npm run e2e:test",
    "e2e:desktop": "npm run e2e:seed && npm run e2e:build && wdio run e2e/wdio/wdio.desktop.conf.ts",
    "e2e:web": "npm run e2e:seed && npm run web:build && cargo build --locked --manifest-path src-tauri/Cargo.toml --bin web_server && wdio run e2e/wdio/wdio.web.conf.ts",
    "e2e:android": "npm run e2e:seed && npm run tauri -- android build --apk --debug && wdio run e2e/wdio/wdio.android.conf.ts",
    "e2e:test:desktop": "wdio run e2e/wdio/wdio.desktop.conf.ts",
    "e2e:test:web": "wdio run e2e/wdio/wdio.web.conf.ts",
    "e2e:test:android": "wdio run e2e/wdio/wdio.android.conf.ts",
    "version:set": "node scripts/set-version.mjs",
    "changelog:extract": "node scripts/extract-changelog.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.{ts,tsx}' 'tests/**/*.ts' 'e2e/**/*.ts'"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2",
    "chart.js": "^4.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@types/better-sqlite3": "^7",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^2.1.8",
    "@wdio/cli": "^9",
    "@wdio/local-runner": "^9",
    "@wdio/mocha-framework": "^9",
    "@wdio/ocr-service": "^2",
    "@wdio/spec-reporter": "^9",
    "@wdio/visual-service": "^6",
    "better-sqlite3": "^12.11.1",
    "cross-env": "^7.0.3",
    "edgedriver": "^6.0.1",
    "eslint": "^10.0.3",
    "eslint-plugin-sonarjs": "^4.0.2",
    "happy-dom": "^15.11.7",
    "tsx": "^4",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
